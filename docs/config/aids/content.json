          "europe",
          "asia",
          "africa"
        ],
        "lightenNonVisited": true
      },
      "image": {
        "visible": false
      }
    },
    {
      "id": "aids-line-01",
      "text": {
        "content": "<p>1996年に世界の年間新規感染者はピークに達し、330万人を数えました。</p>",
        "visible": true,
        "position": {
          "horizontal": "right",
          "vertical": "center",
          "width": "20%"
        }
      },
      "source": {
        "name": "Estimates of global, regional, and national incidence, prevalence, and mortality of HIV, 1980–2015: the Global Burden of Disease Study 2015",
        "url": "https://pmc.ncbi.nlm.nih.gov/articles/PMC5056319/"
      },
      "map": {
        "visible": false
      },
      "image": {
        "visible": false
      },
      "chart": {
        "visible": true,
        "layout": "single",
        "responsive": {
          "mobileStack": true
        },
        "span": {
          "id": "aids-new-infections",
          "continueFromPrevious": true
        },
