          { "id": "pie-cases-americas", "type": "pie", "dataFile": "/data/charts/malariae/regional_distribution.csv", "dataFormat": "csv", "config": { "title": "アメリカ", "rowField": "地域", "rowValue": "アメリカ", "categoryColumns": ["感染者の割合"], "primaryLabel": "感染者", "normalizeTo": 100, "remainderLabel": "非感染者", "remainderColor": "#999999" } },
